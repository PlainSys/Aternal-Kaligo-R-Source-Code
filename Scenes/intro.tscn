[node name="Intro" type="Node2D"]
script = ExtResource("1_rmtiy")

[node name="ColorRect" type="ColorRect" parent="."]
offset_right = 1161.0
offset_bottom = 695.0
color = Color(0, 0, 0, 1)

[node name="text1" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1111.0
offset_bottom = 410.0
theme_override_colors/font_color = Color(0.227451, 0.443137, 0.141176, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"After we killed this polyginol lion... we were hired by these
strange people that were affilated with 'StarCore'...\""
visible_characters = 0
visible_ratio = 0.0

[node name="text2" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 987.0
offset_bottom = 410.0
theme_override_colors/font_color = Color(0.227451, 0.443137, 0.141176, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"Me and my best friend joined since he needed a job
anyways...\""
visible_characters = 0
visible_ratio = 0.0

[node name="text3" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1131.0
offset_bottom = 410.0
theme_override_colors/font_color = Color(0.227451, 0.443137, 0.141176, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"They modified me changed me up and ever since then, I felt
different... if thats the word.\""
visible_characters = 0
visible_ratio = 0.0

[node name="text4" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1132.0
offset_bottom = 476.0
theme_override_colors/font_color = Color(0.227451, 0.443137, 0.141176, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"I've also had a new companion, Yellow... they attached him
to my arm and although it felt weird at first, I quickly loved
the guy...\""
visible_characters = 0
visible_ratio = 0.0

[node name="text5" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1132.0
offset_bottom = 476.0
theme_override_colors/font_color = Color(0.847059, 0.627451, 0, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"Yeah Deciro is a pretty cool dude, he's good at shooting
and shit... fella is amazing.\""
visible_characters = 0
visible_ratio = 0.0

[node name="text6" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1132.0
offset_bottom = 476.0
theme_override_colors/font_color = Color(0.494118, 0.0745098, 0.537255, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"I don't know how to feel about seeing my friend get
modified by these people that I don't even trust.\""
visible_characters = 0
visible_ratio = 0.0

[node name="text7" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1132.0
offset_bottom = 476.0
theme_override_colors/font_color = Color(0.494118, 0.0745098, 0.537255, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"I'm kind of only here just for the job and to find
resources to finish upgrading my sword.\""
visible_characters = 0
visible_ratio = 0.0

[node name="text8" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1132.0
offset_bottom = 476.0
theme_override_colors/font_color = Color(0.494118, 0.0745098, 0.537255, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"I've been through harsh enviormental and melee training.
All to be prepared for this mission that neither me, Deciro,
or Yellow know about...\""
visible_characters = 0
visible_ratio = 0.0

[node name="text9" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1132.0
offset_bottom = 476.0
theme_override_colors/font_color = Color(0.847059, 0.627451, 0, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"They said something about a target??? Bumathule or
something???\""
visible_characters = 0
visible_ratio = 0.0

[node name="text10" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 223.0
offset_right = 1132.0
offset_bottom = 487.0
theme_override_colors/font_color = Color(0.494118, 0.0745098, 0.537255, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"Something about the Dream box, how it came from Egypt
and how it would grant anybody a wish??? They said that
if it was in the wrong hands... aka our target, then the
world would be in danger.\""
visible_characters = 0
visible_ratio = 0.0

[node name="text11" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1111.0
offset_bottom = 410.0
theme_override_colors/font_color = Color(0.227451, 0.443137, 0.141176, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"I feel different... almost like I want to go on a mass murder
spree.\""
visible_characters = 0
visible_ratio = 0.0

[node name="text12" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 278.0
offset_right = 1132.0
offset_bottom = 476.0
theme_override_colors/font_color = Color(0.494118, 0.0745098, 0.537255, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"I'm curious on what they done to him... he just isnt the
same, loveable, robot that I've cherished.\""
visible_characters = 0
visible_ratio = 0.0

[node name="text13" type="Label" parent="."]
visible = false
offset_left = 38.0
offset_top = 257.0
offset_right = 1131.0
offset_bottom = 455.0
theme_override_colors/font_color = Color(0.227451, 0.443137, 0.141176, 1)
theme_override_fonts/font = ExtResource("1_jy7uv")
theme_override_font_sizes/font_size = 22
text = "\"I don't know why they renamed me to Deciro... I wonder 
what that guy from the bar would feel if he found out that
they renamed me from Shooterbot to Deciro.\""
